# DATABASE_URL — Supabase / Neon / Vercel Postgres connection string
DATABASE_URL=postgresql://user:pass@host:5432/postgres

# GHL sync (optional — enables contact match + disposition tags)
GHL_API_KEY=
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_VERSION=2021-07-28
GHL_LOCATION_ID=1oB6OBzWkNBGCcvh2Ann

# 8x8 Work Analytics CDR API (Basic plan — NOT Contact Center)
# Get API key: Admin Console → Analytics → API Keys
# User must have opened Work Analytics in browser at least once
X8X_WORK_API_KEY=
X8X_WORK_USERNAME=
X8X_WORK_PASSWORD=
X8X_WORK_PBX_ID=allpbxes
X8X_WORK_TIMEZONE=America/New_York
X8X_WORK_SYNC_MINUTES=30
X8X_WORK_PAGE_SIZE=200

# Protect CDR import API (n8n WF-CDR sends Bearer token)
IMPORT_API_SECRET=

# Retell webhook verification (optional)
RETELL_WEBHOOK_SECRET=

# Vercel cron auth (optional)
CRON_SECRET=

# Aloware webhook auth (optional query ?token= or Bearer)
ALOWARE_WEBHOOK_SECRET=
